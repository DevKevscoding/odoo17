<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!-- Règle pour restreindre l'accès aux enregistrements de la société actuelle -->
        <record id="live_shopping_line_rule_multi_company" model="ir.rule">
            <field name="name">Live Shopping Multi Société</field>
            <field name="model_id" ref="live_shopping_hr.model_live_shopping_beta"/>
            <field name="global" eval="False"/>
            <field name="domain_force">[('company_id', '=', user.company_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
