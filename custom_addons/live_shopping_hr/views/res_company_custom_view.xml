<?xml version='1.0' encoding='utf-8'?>
<odoo>
  <record id="view_company_form_inherit_custom" model="ir.ui.view">
    <field name="name">res.company.form.inherit.nif.stat.rcs</field>
    <field name="model">res.company</field>
    <field name="inherit_id" ref="base.view_company_form"/>
    <field name="arch" type="xml">
      <xpath expr="//notebook" position="inside">
        <page string="Identification">
          <group>
            <field name="nif"/>
            <field name="stat"/>
            <field name="rcs"/>
          </group>
        </page>
      </xpath>
    </field>
  </record>

  <record id="view_product_form_inherit_live_code_1" model="ir.ui.view">
    <field name="name">product.template.form.live.code</field>
    <field name="model">product.template</field>
    <field name="inherit_id" ref="product.product_template_only_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='default_code']" position="after">
        <field name="code_ref" placeholder="Ex: TSH01"/>
      </xpath>
    </field>
  </record>

  <record id="view_product_form_inherit_live_code_2" model="ir.ui.view">
    <field name="name">product.template.form.live.code</field>
    <field name="model">product.product</field>
    <field name="inherit_id" ref="product.product_normal_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='default_code']" position="after">
        <field name="code_ref" placeholder="Ex: TSH01"/>
      </xpath>
    </field>
  </record>

</odoo>